{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "https://listadeatividades.davixs.com.br/",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": {
            "neq": "listadeatividades.davixs.com.br"
          }
        }
      ]
    },
    {
      "source": "/:path*",
      "destination": "https://listadeatividades.davixs.com.br/:path*",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": {
            "neq": "listadeatividades.davixs.com.br"
          }
        }
      ]
    }
  ]
}
