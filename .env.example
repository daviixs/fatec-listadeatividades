# Variáveis de ambiente para desenvolvimento
# Copie este arquivo para .env e preencha com seus valores

# Chave da API do Resend (obtenha em https://resend.com/api-keys)
RESEND_API_KEY=your-resend-api-key-here

# Email remetente configurado no Resend
RESEND_FROM=no-reply@seudominio.com

# Segredo para proteção de endpoints administrativos
ADMIN_SECRET=your-admin-secret-here
